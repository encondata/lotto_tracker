# Inside docker-compose the backend reaches Postgres at db:5432.
# For local (host) tooling — pytest, alembic — Postgres is published on host port 5433.
DATABASE_URL=postgresql+psycopg://lotto:lotto@db:5432/lotto
# Local host default (used when running outside compose):
# DATABASE_URL=postgresql+psycopg://lotto:lotto@localhost:5433/lotto
CORS_ALLOW_ORIGINS=*
